# Copy to .env and fill in real values
# Never commit .env

# Database — from aws-governance-copilot-infra terraform output
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=governance_copilot
DB_USER=copilot_admin
DB_PASSWORD=your-db-password

# AWS — EC2 instance role handles this automatically on EC2
# For local dev, use your AWS CLI credentials
AWS_REGION=us-east-1

# OpenRouter (fallback LLM — free tier)
OPENROUTER_API_KEY=sk-or-v1-...

# Frontend URL
FRONTEND_URL=http://localhost:3000
